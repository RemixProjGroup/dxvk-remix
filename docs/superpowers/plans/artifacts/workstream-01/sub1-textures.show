+      DecalMaterialInteraction decalMaterialInteraction = decalMaterialInteractionUnpack(memory);
+      
+      // Get sky radiance to blend with
+      vec3 skyRadiance;
+      if (cb.domeLightArgs.active)
+      {
+        skyRadiance = cb.domeLightArgs.radiance * sampleDomeLightTexture(LinearWrapSampler, ray.direction, cb.domeLightArgs.textureIndex, cb.domeLightArgs.worldToLightTransform);
+      }
+      else
+      {
