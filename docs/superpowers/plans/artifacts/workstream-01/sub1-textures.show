+    if (cb.enableDecalsOnSky && geometryResolverState.decalEncountered && decalHitDistance > 0.0f)
+    {
+      // Unpack the decal material
+      MemoryDecalMaterialInteraction memory;
+      memory.packed = decalMemory;
